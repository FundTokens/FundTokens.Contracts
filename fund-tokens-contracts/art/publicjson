  "source": "pragma cashscript ~0.13.0;\r\n\r\ncontract PublicFund(bytes20 bcmrDestination, bytes32 publicToken, bytes32 startupContract)\r\n{   \r\n    function broadcast(bytes fund) {\r\n        require(tx.inputs[this.activeInputIndex - 4].lockingBytecode == new LockingBytecodeP2SH32(startupContract));\r\n\r\n        require(tx.inputs[this.activeInputIndex].lockingBytecode == tx.outputs[this.activeInputIndex + 4].lockingBytecode);\r\n        require(tx.inputs[this.activeInputIndex].tokenCategory == tx.outputs[this.activeInputIndex + 4].tokenCategory);\r\n\r\n        // require(tx.inputs[0].outpointIndex == 0);\r\n        // require(tx.outputs[0].lockingBytecode == new LockingBytecodeP2PKH(bcmrDestination));\r\n        // require(tx.outputs[0].tokenCategory == 0x);\r\n\r\n        // require(tx.inputs[0].outpointTransactionHash == nft_fundCategory);\r\n        // require(tx.outputs[this.activeInputIndex + 7].tokenCategory == nft_fundCategory);\r\n        // require(tx.outputs[this.activeInputIndex + 7].tokenAmount == 9223372036854775807); // anything but the max?\r\n\r\n        require(bcmrDestination != 0x);\r\n        require(publicToken != 0x);\r\n\r\n\r\n        bytes nft_fundCategory, bytes nft_next1 = fund.split(32);\r\n        require(nft_fundCategory != 0x);\r\n        bytes nft_fundAmount, bytes nft_next2 = nft_next1.split(8);\r\n        require(int(nft_fundAmount) > 0);\r\n        bytes nft_satoshis, bytes nft_assets = nft_next2.split(8);\r\n        require(within(int(nft_satoshis), 0, 2100000000000000));\r\n\r\n        bytes lastAssetCategory = 0x;\r\n        do {\r\n            bytes nft_assetCategory, bytes nft_next3 = nft_assets.split(32);\r\n            bytes nft_assetAmount, bytes nft_next4 = nft_next3.split(8);\r\n            require(int(nft_assetAmount) > 0);\r\n\r\n            if(lastAssetCategory != 0x) {\r\n                require(int(lastAssetCategory + 0x00) < int(nft_assetCategory + 0x00));\r\n            }\r\n\r\n            nft_assets = nft_next4;\r\n            lastAssetCategory = nft_assetCategory;\r\n        } while(nft_assets.length > 0);\r\n    }\r\n}\r\n",

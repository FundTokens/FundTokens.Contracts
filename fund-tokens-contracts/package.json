{
  "name": "fund-tokens-contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "dependencies": {
    "cashc": "0.13.0-next.6",
    "cashscript": "0.13.0-next.6"
  },
  "scripts": {
    "test": "vitest run",
    "test:build": "yarn build && yarn test",
    "test:watch": "vitest",
    "build": "yarn build:fund && yarn build:startup && yarn build:system",
    "build:fund": "cashc ./contracts/manager.cash --output ./lib/art/manager.json && cashc ./contracts/fund.cash --output ./lib/art/fund.json && cashc ./contracts/asset.cash --output ./lib/art/asset.json",
    "build:startup": "cashc ./contracts/public.cash --output ./lib/art/public.json && cashc ./contracts/startup.cash --output ./lib/art/startup.json && cashc ./contracts/fee.cash --output ./lib/art/fee.json && cashc ./contracts/mint.cash --output ./lib/art/mint.json",
    "build:system": "cashc ./contracts/fee_minter.cash --output ./lib/art/fee_minter.json && cashc ./contracts/simple_minter.cash --output ./lib/art/simple_minter.json"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}

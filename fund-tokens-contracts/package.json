{
  "name": "fund-tokens-contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "dependencies": {
    "cashc": "0.13.0-next.4",
    "cashscript": "0.13.0-next.4"
  },
  "scripts": {
    "mock": "node ./mock.js",
    "build": "yarn build:fund && yarn build:startup && yarn build:system",
    "build:fund": "cashc ./contracts/manager.cash --output ./builders/art/manager.json && cashc ./contracts/fund.cash --output ./builders/art/fund.json && cashc ./contracts/asset.cash --output ./builders/art/asset.json",
    "build:startup": "cashc ./contracts/public.cash --output ./builders/art/public.json && cashc ./contracts/startup.cash --output ./builders/art/startup.json && cashc ./contracts/fee.cash --output ./builders/art/fee.json && cashc ./contracts/mint.cash --output ./builders/art/mint.json",
    "build:system": "cashc ./contracts/fee_minter.cash --output ./builders/art/fee_minter.json && cashc ./contracts/simple_minter.cash --output ./builders/art/simple_minter.json"
  }
}

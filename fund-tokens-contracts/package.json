{
  "name": "fundTokens-contracts",
  "version": "0.0.2",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "dependencies": {
    "cashc": "0.13.0-next.1",
    "cashscript": "0.13.0-next.1"
  },
  "scripts": {
    "mock": "yarn build && node ./mock.js",
    "build": "yarn build:fund && yarn build:startup && yarn build:system",
    "build:fund": "cashc ./manager.cash --output ./art/manager.json && cashc ./fund.cash --output ./art/fund.json && cashc ./asset.cash --output ./art/asset.json",
    "build:startup": "cashc ./public.cash --output ./art/publicjson && cashc ./startup.cash --output ./art/startup.json && cashc ./fee.cash --output ./art/fee.json && cashc ./mint.cash --output ./art/mint.json",
    "build:system": "cashc ./fee_minter.cash --output ./art/fee_minter.json && cashc ./simple_minter.cash --output ./art/simple_minter.json"
  }
}
